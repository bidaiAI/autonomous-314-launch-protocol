INDEXER_CHAIN_ID=56
INDEXER_RPC_URL=https://bsc-dataseed.binance.org
INDEXER_FACTORY_ADDRESS=0x09261904bf6f7Ce23dee2058379A49DF53B80314

# Production: pin this to the factory deployment block to avoid losing older launches after restarts.
INDEXER_FROM_BLOCK=
INDEXER_LOOKBACK_BLOCKS=50000
INDEXER_LOG_BATCH_BLOCKS=10
INDEXER_LAUNCH_LIMIT=25
INDEXER_ACTIVITY_LIMIT=40

# Static snapshot output path used by `pnpm snapshot:indexer`
INDEXER_OUTPUT_PATH=../web/public/data/indexer-snapshot.json

# Dynamic API mode used by `pnpm serve:indexer`
INDEXER_PORT=8787
INDEXER_CACHE_TTL_MS=15000
INDEXER_CORS_ORIGIN=https://your-frontend.vercel.app
