INDEXER_CHAIN_ID=56
INDEXER_RPC_URL=https://bsc-dataseed.binance.org
INDEXER_FACTORY_ADDRESS=0xa5d62930AA7CDD332B6bF1A32dB0cC7095FC0314

# Production: pin this to the factory deployment block to avoid losing older launches after restarts.
INDEXER_FROM_BLOCK=91258253
# Optional upper bound for historical smoke tests / bounded snapshots.
# Example: point an old factory deployment at a narrow block window instead of scanning to the latest head.
# INDEXER_TO_BLOCK=91299999
INDEXER_LOOKBACK_BLOCKS=50000
INDEXER_LOG_BATCH_BLOCKS=10
INDEXER_LAUNCH_LIMIT=25
INDEXER_ACTIVITY_LIMIT=40

# Static snapshot output path used by `pnpm snapshot:indexer`
INDEXER_OUTPUT_PATH=../web/public/data/indexer-snapshot.json

# Dynamic API mode used by `pnpm serve:indexer`
INDEXER_PORT=8787
INDEXER_CACHE_TTL_MS=15000
INDEXER_CORS_ORIGIN=https://auto314.cc
INDEXER_X_CLIENT_ID=
INDEXER_X_CLIENT_SECRET=
INDEXER_X_CALLBACK_URL=https://indexer-production-570f.up.railway.app/auth/x/callback
INDEXER_X_SCOPES=tweet.read tweet.write users.read offline.access
INDEXER_X_ACCOUNT_ACCESS_TOKEN=
INDEXER_X_ACCOUNT_REFRESH_TOKEN=
# Required for any public POST /api/x/tweets call.
INDEXER_X_POST_SHARED_SECRET=
# Optional: require bearer auth for metadata uploads except from these public origins.
INDEXER_METADATA_POST_SHARED_SECRET=
INDEXER_METADATA_PUBLIC_ORIGINS=https://auto314.cc,http://localhost:5173,http://127.0.0.1:5173
INDEXER_MAX_IMAGE_UPLOAD_BYTES=8388608

# Social notifications
INDEXER_SOCIAL_NOTIFY_ENABLED=0
INDEXER_SOCIAL_NOTIFY_INTERVAL_MS=60000
INDEXER_SOCIAL_NOTIFY_BASE_URL=https://auto314.cc
INDEXER_SOCIAL_NOTIFY_X_ENABLED=1
INDEXER_SOCIAL_NOTIFY_PROJECT_TELEGRAM_ENABLED=1
INDEXER_SOCIAL_NOTIFY_ALERT_TELEGRAM_ENABLED=1
INDEXER_SOCIAL_NOTIFY_MARKET_CAP_THRESHOLDS_USD=100000,500000,1000000
INDEXER_NATIVE_USD_PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=binancecoin&vs_currencies=usd

# Base chain profile (single-chain deployment)
# INDEXER_CHAIN_ID=8453
# INDEXER_RPC_URL=https://mainnet.base.org
# INDEXER_FACTORY_ADDRESS=0x6fDE83bB814AC79D1267695d532e2Dd9d16A0314
# INDEXER_FROM_BLOCK=44505311
# INDEXER_PUBLIC_BASE_URL=https://indexer-base-production.up.railway.app
# INDEXER_SOCIAL_NOTIFY_BASE_URL=https://your-base-app.example.com
# INDEXER_METADATA_PUBLIC_ORIGINS=https://your-base-app.example.com
# INDEXER_CORS_ORIGIN=https://your-base-app.example.com
# INDEXER_ETHERSCAN_API_URL=https://api.basescan.org/api
# INDEXER_BASESCAN_API_URL=https://api.basescan.org/api
# INDEXER_X_CALLBACK_URL=https://your-base-indexer.example.com/auth/x/callback
# INDEXER_NATIVE_USD_PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=ethereum&vs_currencies=usd
# INDEXER_AUTO_VERIFY_BOOTSTRAP_OFFICIAL=1
# INDEXER_SOCIAL_NOTIFY_ENABLED=0

# Official project channel (used for official channel broadcasts / X-synced automation)
INDEXER_TELEGRAM_PROJECT_BOT_TOKEN=
INDEXER_TELEGRAM_PROJECT_CHAT_ID=
INDEXER_TELEGRAM_PROJECT_MESSAGE_THREAD_ID=

# Alerts channel (used for new-launch alerts)
INDEXER_TELEGRAM_ALERT_BOT_TOKEN=
INDEXER_TELEGRAM_ALERT_CHAT_ID=
INDEXER_TELEGRAM_ALERT_MESSAGE_THREAD_ID=

# Automatic open-source / verification worker
INDEXER_AUTO_VERIFY_ENABLED=1
INDEXER_AUTO_VERIFY_INTERVAL_MS=60000
INDEXER_AUTO_VERIFY_MIN_CONFIRMATIONS=2
INDEXER_AUTO_VERIFY_MAX_TARGETS_PER_RUN=6
INDEXER_AUTO_VERIFY_BOOTSTRAP_OFFICIAL=1
INDEXER_SOURCIFY_SERVER_URL=https://sourcify.dev/server
INDEXER_ETHERSCAN_API_URL=https://api.etherscan.io/v2/api
# Optional extra explorer-verification paths.
# - Etherscan V2 key: works through https://api.etherscan.io/v2/api with chainid routing.
# - Chain-specific key only: also set the matching *_API_URL (or use the Base/BSC chain defaults above).
INDEXER_ETHERSCAN_API_KEY=
# Legacy fallback for older explorer setups.
INDEXER_BSCSCAN_API_KEY=
# Optional BaseScan API key for Base deployments.
INDEXER_BASESCAN_API_KEY=
