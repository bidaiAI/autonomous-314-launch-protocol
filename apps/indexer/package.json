{
  "name": "@autonomous314/indexer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "snapshot": "pnpm build && node dist/main.js",
    "serve": "tsx src/server.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "start:snapshot": "node dist/main.js",
    "sync:verification-artifacts": "node scripts/sync-verification-artifacts.mjs",
    "verify:once": "tsx src/verify-once.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "viem": "^2.38.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
